<div class="card">
  <div class="card-header">
    <h1>Dodaj nowego użytkownika</h1>
  </div>
  <div class="card-body">
    <%= form_with(model: @user, local: true) do |f| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@user.errors.count, "błąd") %> uniemożliwił zapisanie:</h4>
          <ul>
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-group">
        <%= f.label :first_name, "Imię" %>
        <%= f.text_field :first_name, class: 'form-control', required: true %>
      </div>

      <div class="form-group">
        <%= f.label :last_name, "Nazwisko" %>
        <%= f.text_field :last_name, class: 'form-control', required: true %>
      </div>

      <div class="form-group">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, class: 'form-control', required: true %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Hasło" %>
        <%= f.password_field :password, class: 'form-control', required: true %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Potwierdź hasło" %>
        <%= f.password_field :password_confirmation, class: 'form-control', required: true %>
      </div>

      <div class="actions">
        <%= f.submit "Dodaj użytkownika", class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
  <div class="card-footer">
    <%= link_to 'Wróć', users_path, class: 'btn btn-secondary' %>
  </div>
</div>