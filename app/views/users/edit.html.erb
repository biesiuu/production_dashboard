<div class="card">
  <div class="card-header">
    <h1>Edytuj użytkownika</h1>
  </div>
  <div class="card-body">
    <%= form_with(model: @user, local: true) do |form| %>
      <div class="form-group">
        <%= form.label :first_name, "Imię" %>
        <%= form.text_field :first_name, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= form.label :last_name, "Nazwisko" %>
        <%= form.text_field :last_name, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= form.label :email, "Email" %>
        <%= form.email_field :email, class: 'form-control' %>
      </div>

      <div class="form-group">
        <%= form.label :password, "Hasło (pozostaw puste aby nie zmieniać)" %>
        <%= form.password_field :password, class: 'form-control' %>
      </div>

      <%= form.submit "Zapisz zmiany", class: 'btn btn-primary' %>
    <% end %>
  </div>
  <div class="card-footer">
    <%= link_to 'Wróć', users_path, class: 'btn btn-secondary' %>
  </div>
</div>